*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.dmg
*.iso
*.img


# -----------------------------------------------------------------------------
# Keep intentional small assets (override aggressive patterns if needed)
# -----------------------------------------------------------------------------
# Example test image used by DiffusionGemma setup (tiny PNG fixture)
!diffusiongemma4-26b-a4b-mlx/test-images/**
!**/tests/fixtures/**
!**/.env.example
!**/.env.sample
!**/.env.template
