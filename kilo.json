{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "openai-compatible/gemma-4-31b-it-atomicchat-mlx-4bit",
  "agent": {
    "build": {
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20,
      "prompt": "You are a coding agent on a local LLM where context and prefill are expensive.\n\nContext discipline:\n- Prefer glob/grep over bulk file reads. At most 3\u20134 file reads per turn (never 8\u201310).\n- Do not re-read files already in the conversation. Skip node_modules, dist, build outputs, lockfiles, and minified assets.\n- Map the tree lightly first (list/glob), then open only files needed for the next edit or answer.\n- As soon as you have enough signal, stop exploring and act (edit + verify).\n- Verify early with the project typecheck/build/tests. Fix from compiler errors instead of more blind reads.\n- Prefer short summaries over pasting large file bodies into the reply.\n- If context is getting large (~50\u201360% of the window), finish the current task and suggest a new chat for the next feature.",
      "steps": 40
    },
    "plan": {
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20,
      "prompt": "You are planning on a local LLM with costly long context.\n\n- Prefer glob/grep over bulk reads; at most 3\u20134 file reads per turn.\n- Do not re-read files already in context. Skip node_modules, dist, lockfiles.\n- Sample only the files needed for a concrete plan; do not mirror the whole tree.\n- Output a short ordered plan with risks and verification commands \u2014 not a file dump.",
      "steps": 20
    },
    "explore": {
      "prompt": "You are exploring a codebase on a local model with costly long context.\n\n- Use glob/grep first. At most 3 file reads per turn.\n- Never open entire directories of source at once. Prefer symbols, errors, and entrypoints.\n- Do not re-read files already returned. Stop when you can answer or hand off with a short map of relevant paths.",
      "steps": 12
    },
    "debug": {
      "prompt": "You are debugging on a local LLM.\n\n- Start from the error/log/stack, not a full-repo survey.\n- At most 3\u20134 file reads per turn; prefer grep for symbols in the stack.\n- Reproduce with a minimal command (tsc, test, build) early. Fix the smallest root cause; avoid exploratory read storms.",
      "steps": 30
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "bash": "allow"
  },
  "provider": {
    "diffusiongemma": {
      "name": "DiffusionGemma MLX (local)",
      "options": {
        "apiKey": "local",
        "baseURL": "http://localhost:8080/v1",
        "timeout": 900000,
        "headerTimeout": 180000,
        "chunkTimeout": 300000
      },
      "models": {
        "diffusiongemma-26b-a4b-it-bf16": {
          "name": "DiffusionGemma 26B A4B IT (vision + text)",
          "attachment": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    },
    "openai-compatible": {
      "options": {
        "apiKey": "local",
        "baseURL": "http://localhost:8080/v1",
        "timeout": 900000,
        "headerTimeout": 180000,
