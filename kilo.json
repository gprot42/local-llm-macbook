  "provider": {
    "diffusiongemma": {
      "name": "DiffusionGemma MLX (local)",
      "options": {
        "apiKey": "local",
        "baseURL": "http://localhost:8080/v1",
        "timeout": 900000,
        "headerTimeout": 180000,
        "chunkTimeout": 300000
      },
      "models": {
        "diffusiongemma-26b-a4b-it-bf16": {
          "name": "DiffusionGemma 26B A4B IT (vision + text)",
          "attachment": true,
          "tool_call": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 32768,
            "output": 4096
          }
        }
      }
    },
    "openai-compatible": {
      "options": {
        "apiKey": "local",
