{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "glm/glm-4.7-flash-heretic-q8",
  "agent": {
    "build": {
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20
    },
    "plan": {
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20
    }
