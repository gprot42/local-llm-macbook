{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "ds4/deepseek-v4-flash",
  "agent": {
    "build": {
      "temperature": 1.0,
      "top_p": 1.0
    },
    "plan": {
      "temperature": 1.0,
      "top_p": 1.0
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "bash": "allow"
  },
  "provider": {
    "ds4": {
      "name": "DwarfStar ds4 (DeepSeek V4 native Metal)",
      "options": {
        "apiKey": "local",
        "baseURL": "http://127.0.0.1:8083/v1",
        "timeout": 900000,
        "headerTimeout": 180000,
        "chunkTimeout": 300000
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (ds4 q2-imatrix, ~81 GB) — native Metal + tools",
          "tool_call": true,
          "limit": {
            "context": 100000,
            "output": 32768
          }
        }
      }
    }
  }
}
