{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "openai-compatible/gemma-4-31b-it-atomicchat-mlx-4bit",
  "agent": {
    "build": {
      "temperature": 0.35,
      "top_p": 0.95
    },
    "plan": {
      "temperature": 0.15,
      "top_p": 0.95
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "bash": "allow"
  },
  "provider": {
    "openai-compatible": {
      "options": {
        "apiKey": "local",
        "baseURL": "http://localhost:8080/v1",
        "timeout": 900000,
        "headerTimeout": 180000,
        "chunkTimeout": 300000
      },
      "models": {
        "gemma-4-31b-it-atomicchat-mlx-4bit": {
          "name": "Gemma 4 31B IT AtomicChat (MLX 4-bit, 2026-07-15) — text only, aligned stock",
          "tool_call": true,
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
}