{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "openai-compatible/gemma-4-31b-heretic-mlx-4bit",
  "agent": {
    "build": {
      "temperature": 0.35,
      "top_p": 0.95
    },
    "plan": {
      "temperature": 0.15,
      "top_p": 0.95
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "bash": "allow"
  },
  "provider": {
    "openai-compatible": {
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "gemma-4-31b-heretic-mlx-4bit": {
          "name": "Gemma 4 31B Heretic (MLX 4-bit) — uncensored",
          "attachment": true,
          "tool_call": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
}
