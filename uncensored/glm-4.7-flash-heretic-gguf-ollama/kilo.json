{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "glm/glm-4.7-flash-heretic-q8",
  "agent": {
    "build": {
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20
    },
    "plan": {
      "temperature": 0.6,
      "top_p": 0.95,
      "top_k": 20
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "bash": "allow"
  },
  "provider": {
    "glm": {
      "name": "GLM-4.7-Flash Heretic (Ollama GGUF, uncensored)",
      "options": {
        "apiKey": "local",
        "baseURL": "http://127.0.0.1:18083/v1",
        "timeout": 900000,
        "headerTimeout": 180000,
        "chunkTimeout": 300000
      },
      "models": {
        "glm-4.7-flash-heretic-q8": {
          "name": "GLM-4.7-Flash Heretic Q8_0 — uncensored max quality (~32 GB)",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 65536
          }
        }
      }
    }
  }
}
